{
  "name": "controller",
  "version": "1.0.0",
  "description": "Meta-controller system — capability schemas, decision models, and MCP evaluation server",
  "private": true,
  "workspaces": [
    "mcp-server"
  ],
  "scripts": {
    "install:mcp": "cd mcp-server && npm install",
    "dev": "cd mcp-server && npm run dev",
    "build": "cd mcp-server && npm run build",
    "start": "cd mcp-server && npm run start",
    "clean": "rm -rf mcp-server/dist mcp-server/*.tsbuildinfo",
    "lint": "cd mcp-server && npx tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gtgspot/controller"
  }
}
