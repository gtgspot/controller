{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/execution-trace-item.schema.json",
  "title": "ExecutionTraceItem",
  "type": "object",
  "additionalProperties": false,
  "required": ["step", "capability", "status"],
  "properties": {
    "step": {
      "type": "integer",
      "minimum": 1
    },
    "capability": {
      "type": "string",
      "enum": [
        "ambiguity_scan",
        "implicit_premise_extraction",
        "rhetorical_move_mapping",
        "pragmatic_inference",
        "coherence_graph",
        "semantic_density_control",
        "register_detection",
        "stylometry",
        "contradiction_detection",
        "burden_mapping",
        "jurisdictional_precondition_check",
        "evidence_source_tracing",
        "adversarial_simulation",
        "materiality_filter",
        "remedy_mapping"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["executed", "skipped", "blocked", "failed", "escalated"]
    },
    "reason": {
      "type": "string"
    },
    "checkpoint_result": {
      "$ref": "https://example.org/schemas/checkpoint-result.schema.json"
    }
  }
}
