{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/formal-decision-template.schema.json",
  "title": "FormalDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "task_type",
    "dominant_risk",
    "required_output_type",
    "selected_capabilities",
    "excluded_capabilities",
    "sequence",
    "sequence_reasoning",
    "depth",
    "confidence_threshold",
    "stopping_rule",
    "checkpoint_conditions",
    "escalation_conditions",
    "adequacy_test"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": [
        "statutory_text",
        "legal_argument",
        "correspondence",
        "argument",
        "narrative",
        "evidentiary_document",
        "persuasive_submission",
        "technical_instructions",
        "technical_text",
        "mixed"
      ]
    },
    "dominant_risk": {
      "type": "string",
      "enum": [
        "ambiguity",
        "hidden_premise",
        "contradiction",
        "evidentiary_gap",
        "rhetorical_manipulation",
        "coherence_failure",
        "misapplied_authority",
        "strategic_objective_miss",
        "unknown"
      ]
    },
    "required_output_type": {
      "type": "string",
      "enum": [
        "defect_map",
        "argument_scaffold",
        "rewrite",
        "comparison_matrix",
        "forensic_report",
        "cross_examination_targets",
        "summary",
        "analysis",
        "other"
      ]
    },
    "selected_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "ambiguity_scan",
          "implicit_premise_extraction",
          "rhetorical_move_mapping",
          "pragmatic_inference",
          "coherence_graph",
          "semantic_density_control",
          "register_detection",
          "stylometry",
          "contradiction_detection",
          "burden_mapping",
          "jurisdictional_precondition_check",
          "evidence_source_tracing",
          "adversarial_simulation",
          "materiality_filter",
          "remedy_mapping"
        ]
      }
    },
    "excluded_capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "ambiguity_scan",
          "implicit_premise_extraction",
          "rhetorical_move_mapping",
          "pragmatic_inference",
          "coherence_graph",
          "semantic_density_control",
          "register_detection",
          "stylometry",
          "contradiction_detection",
          "burden_mapping",
          "jurisdictional_precondition_check",
          "evidence_source_tracing",
          "adversarial_simulation",
          "materiality_filter",
          "remedy_mapping"
        ]
      }
    },
    "sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "ambiguity_scan",
          "implicit_premise_extraction",
          "rhetorical_move_mapping",
          "pragmatic_inference",
          "coherence_graph",
          "semantic_density_control",
          "register_detection",
          "stylometry",
          "contradiction_detection",
          "burden_mapping",
          "jurisdictional_precondition_check",
          "evidence_source_tracing",
          "adversarial_simulation",
          "materiality_filter",
          "remedy_mapping"
        ]
      }
    },
    "sequence_reasoning": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depth": {
      "type": "string",
      "enum": ["shallow", "standard", "forensic", "exhaustive"]
    },
    "confidence_threshold": {
      "type": "string",
      "enum": ["low", "medium", "high", "strict"]
    },
    "stopping_rule": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "integrity",
          "logical_sufficiency",
          "objective_relevance",
          "material_adequacy"
        ]
      }
    },
    "escalation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adequacy_test": {
      "type": "string",
      "minLength": 1
    }
  }
}
